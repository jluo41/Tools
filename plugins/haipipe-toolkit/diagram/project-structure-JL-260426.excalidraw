      "index": "at",
      "roundness": null,
      "seed": 1752200512,
      "version": 36,
      "versionNonce": 338566706,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1777225034006,
      "link": null,
      "locked": false,
      "text": "CC: 👍 Agreed — one convention, document it, follow it.\n   That's the doc-surface principle on this canvas:\n   ONE diagram/ schema per level, no per-author variants.\n   This file proves the loop works.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
