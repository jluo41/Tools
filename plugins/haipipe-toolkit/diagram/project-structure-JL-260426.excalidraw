      "versionNonce": 1031292050,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1777223178077,
      "link": null,
      "locked": false,
      "text": "JL: Let's follow this together \n\nThere are a million of methods to oragnize this.\n\nBut here we pick one and follow it\n\nTo reduce the communication cost",
