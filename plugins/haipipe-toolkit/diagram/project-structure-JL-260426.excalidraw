      "seed": 95731135,
      "version": 199,
      "versionNonce": 772088050,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1777224669247,
      "link": null,
      "locked": false,
      "text": "CC: ✅ Will bake into 01-shape.txt\n§5 (Authoring pipeline):\n\n  {level}.excalidraw\ncanonical, regenerated from .txt\n  {level}-{XX}-\n{YYMMDD}.excalidraw   annotated\nfork, never regenerated\n                                      XX\n= initials  YYMMDD = date\n\n  Loop: human annotates fork →\nmaintainers update .txt sources\n  in response → canonical\nregenerated → forks live alongside\nas\n  review history (this file is the\nfirst JL fork).",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "CC: ✅ Will bake into 01-shape.txt §5 (Authoring pipeline):\n\n  {level}.excalidraw                  canonical, regenerated from .txt\n  {level}-{XX}-{YYMMDD}.excalidraw   annotated fork, never regenerated\n                                      XX = initials  YYMMDD = date\n\n  Loop: human annotates fork → maintainers update .txt sources\n  in response → canonical regenerated → forks live alongside as\n  review history (this file is the first JL fork).",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "LcNqDWmfDILYlScllhep9",
      "type": "text",
      "x": 720,
      "y": 1535,
      "width": 566.1733205724182,
      "height": 100,
      "angle": 0,
      "strokeColor": "#9c36b5",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
