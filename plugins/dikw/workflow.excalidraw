    {
      "type": "text", "id": "s2_snap_tree", "x": 70, "y": 440, "width": 580, "height": 340,
      "text": "├── manifest.yaml\n│\n├── source/                    INPUT — data files\n│     CGM.parquet, Diet.parquet, …\n│\n├── exploration/               produced once by /dikw-explore\n│   └── explore_notes.md\n│\n└── insights/                  D/I/K/W per-task outputs\n    ├── data/D{NN}-{task}/\n    │     report.md + analysis.py\n    ├── information/I{NN}-{task}/\n    │     report.md + analysis.py\n    ├── knowledge/K{NN}-{task}/\n    │     report.md (reasoning only)\n    └── wisdom/W{NN}-{task}/\n          report.md (reasoning only)",
      "originalText": "├── manifest.yaml\n│\n├── source/                    INPUT — data files\n│     CGM.parquet, Diet.parquet, …\n│\n├── exploration/               produced once by /dikw-explore\n│   └── explore_notes.md\n│\n└── insights/                  D/I/K/W per-task outputs\n    ├── data/D{NN}-{task}/\n    │     report.md + analysis.py\n    ├── information/I{NN}-{task}/\n    │     report.md + analysis.py\n    ├── knowledge/K{NN}-{task}/\n    │     report.md (reasoning only)\n    └── wisdom/W{NN}-{task}/\n          report.md (reasoning only)",
      "fontSize": 13, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top",
      "strokeColor": "#374151", "backgroundColor": "transparent", "fillStyle": "solid",
      "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100,
