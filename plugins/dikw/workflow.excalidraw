    {
      "type": "text", "id": "s2_sess_tree", "x": 70, "y": 860, "width": 580, "height": 340,
      "text": "sessions/\n└── {aim}/               aim = NN_{slug}, e.g. 01_cgm-pattern-inventory\n    ├── question.md\n    ├── plan/\n    │     plan-raw.yaml                    (symlink → latest v)\n    │     plan-raw-v1.yaml, v2.yaml, …     one per plan revision\n    ├── gates/\n    │     00-G-plan.md, 01-G-D.md, …       sequential NN counter\n    │     02-G-I.md, 03-G-plan.md (v2),…\n    ├── output/\n    │     final_output.md                  written by /dikw-report\n    └── DIKW_STATE.json                    phase · step · gate_persona · history",
      "originalText": "sessions/\n└── {aim}/               aim = NN_{slug}, e.g. 01_cgm-pattern-inventory\n    ├── question.md\n    ├── plan/\n    │     plan-raw.yaml                    (symlink → latest v)\n    │     plan-raw-v1.yaml, v2.yaml, …     one per plan revision\n    ├── gates/\n    │     00-G-plan.md, 01-G-D.md, …       sequential NN counter\n    │     02-G-I.md, 03-G-plan.md (v2),…\n    ├── output/\n    │     final_output.md                  written by /dikw-report\n    └── DIKW_STATE.json                    phase · step · gate_persona · history",
      "fontSize": 13, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top",
      "strokeColor": "#374151", "backgroundColor": "transparent", "fillStyle": "solid",
