    {
      "type": "text", "id": "s4_table", "x": 1810, "y": 550, "width": 520, "height": 180,
      "text": "preset     strict  amb   default route\n─────────  ──────  ───   ─────────────────\nstrict       8      4    revise plan    (CI must exclude target)\nbalanced     5      5    revise plan    (current behavior)\ncreative     3      8    approve        (push for richer K/W)\nlenient      2      3    approve        (only fail missing files)",
      "originalText": "preset     strict  amb   default route\n─────────  ──────  ───   ─────────────────\nstrict       8      4    revise plan    (CI must exclude target)\nbalanced     5      5    revise plan    (current behavior)\ncreative     3      8    approve        (push for richer K/W)\nlenient      2      3    approve        (only fail missing files)",
