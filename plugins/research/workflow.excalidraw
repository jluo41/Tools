    {
      "type": "text", "id": "sup_dev_t",
      "x": 100, "y": 655, "width": 380, "height": 125,
      "text": "🧑‍💻 Dev utilities\n\n  📋 coding-by-logging  —  review & iterate via docs\n  📊 evaluation-display-skill  —  tables + figures from results\n  📓 notebook-cell-python  —  script ↔ notebook ↔ markdown",
      "originalText": "🧑‍💻 Dev utilities\n\n  📋 coding-by-logging  —  review & iterate via docs\n  📊 evaluation-display-skill  —  tables + figures from results\n  📓 notebook-cell-python  —  script ↔ notebook ↔ markdown",
      "fontSize": 13, "fontFamily": 3,
