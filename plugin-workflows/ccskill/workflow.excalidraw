      "x": 140, "y": 315, "width": 280, "height": 30,
      "text": "🎨 CREATIVE & DESIGN",
      "originalText": "🎨 CREATIVE & DESIGN",
      "fontSize": 15, "fontFamily": 3,
      "textAlign": "center", "verticalAlign": "top",
      "strokeColor": "#6d28d9", "backgroundColor": "transparent",
